{
  "name": "settlers.ts",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit & FAST_BUILD=1 vite build; wait",
    "build:full": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "lint": "oxlint --type-aware src tests & vue-tsc --noEmit & eslint --cache --cache-location node_modules/.cache/eslint/ src tests; wait",
    "lint:fix": "eslint src tests --fix",
    "format": "oxfmt --write \"src/**/*.{ts,vue}\"",
    "format:check": "oxfmt --check \"src/**/*.{ts,vue}\"",
    "cli": "tsx scripts/cli.ts",
    "timeline": "node scripts/timeline.mjs",
    "timeline:record": "tsx scripts/timeline-receiver.ts",
    "timeline:live": "pnpm timeline -- --dir live",
    "analyze:circular": "madge --circular --extensions ts src/",
    "analyze:type-coverage": "type-coverage --project tsconfig.json --detail --strict",
    "analyze:unused": "knip",
    "analyze:duplication": "jscpd src",
    "analyze:deps": "depcruise src --config .dependency-cruiser.cjs",
    "analyze:utils": "tsx scripts/analyze-utils.ts",
    "analyze": "pnpm analyze:circular && pnpm analyze:deps && pnpm analyze:unused && pnpm analyze:duplication && pnpm analyze:utils",
    "gfx:export": "tsx --tsconfig tsconfig.json scripts/gfx-export/cli.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/vue-virtual": "^3.13.19",
    "@vueuse/core": "^14.2.1",
    "fengari": "^0.1.5",
    "fengari-interop": "^0.1.4",
    "howler": "^2.2.4",
    "loglevel": "^1.9.2",
    "superjson": "^2.2.6",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vue-toastification": "2.0.0-rc.5"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "oxfmt --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@rollup/pluginutils": "^5.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/howler": "^2.2.12",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260312.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "better-sqlite3": "^12.6.2",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "jsdom": "^28.1.0",
    "knip": "^5.84.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.54.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsx": "^4.21.0",
    "type-coverage": "^2.29.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vite-plugin-glsl": "^1.5.5",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
