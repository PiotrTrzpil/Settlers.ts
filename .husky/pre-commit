# Run lint-staged only if there are lintable files staged
LINTABLE=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|vue)$' || true)
if [ -n "$LINTABLE" ]; then
    pnpm lint-staged
fi

# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  ⚠️  CRITICAL: OPTIMISTIC PROGRAMMING - READ THIS ⚠️                        ║
# ║                                                                            ║
# ║  This codebase uses OPTIMISTIC programming patterns.                       ║
# ║  DEFENSIVE CODE HIDES BUGS AND WILL BE REJECTED.                           ║
# ║                                                                            ║
# ║  If value MUST exist at that point, these are BUGS:                        ║
# ║    • this.foo?.bar()     → this.foo!.bar()                                 ║
# ║    • x ?? defaultValue   → x!                                              ║
# ║    • if (x) { x.y() }    → x!.y()  (when x is required, not optional)      ║
# ║    • foo?: Type          → foo: Type (when always provided)                ║
# ╚════════════════════════════════════════════════════════════════════════════╝

STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v '\.spec\.ts$' | grep -v '\.test\.ts$' || true)

if [ -n "$STAGED_TS_FILES" ]; then
    echo ""
    echo "⚠️  OPTIMISTIC PROGRAMMING — check for: ?. on required deps, silent fallbacks (?? 0), defensive guards on guaranteed values. See CLAUDE.md."
    echo ""

    # Check for high-confidence violations
    VIOLATIONS=$(echo "$STAGED_TS_FILES" | xargs grep -n 'this\.\(eventBus\|gameState\|inventoryManager\|carrierSystem\|requestManager\)?\.' 2>/dev/null | grep -v '// ok-defensive' || true)

    if [ -n "$VIOLATIONS" ]; then
        echo "  Likely violations:"
        echo "$VIOLATIONS" | sed 's/^/    /'
        echo ""
    fi
fi
